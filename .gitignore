# Rust / Cargo build artifacts
/target
debug/
**/*.rs.bk

# Cargo lock for binaries is fine, but uncommit if this becomes a library
# Cargo.lock

# Compiler artifacts
*.d
*.rlib
*.rmeta
*.pdb

# Profiling and coverage
*.profraw
*.profdata
*.gcno
*.gcda
tarpaulin-report.html
lcov.info

# IDE / editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Environment
.env
.env.*

# Code review reports (local-only)
/CODE_REVIEW.md

# Session/orchestration state (local-only)
/.sisyphus/
/.omo/

# Local-only throwaway build spikes (e.g. MIPS nightly feasibility); never committed
/.spike-mips/

# Node.js artifacts (some agent tooling installs these in the worktree;
# this project is pure Rust and should NEVER track JS dependencies)
/node_modules/
/package.json
/package-lock.json
/bun.lock
/bun.lockb
/yarn.lock

# Certificate and key material
*.pem
*.crt
*.cer
*.der
*.key
*.p12
*.pfx
*.csr
*.ca-bundle
*.chain
certs/
certificates/
private_keys/

# Local-only custom build/runtime overlays (Containerfile.custom, etc.)
*.custom
